{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/industries", "dest": "/industries.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/packages/foundation", "dest": "/packages/foundation.html" },
    { "src": "/packages/market-leader", "dest": "/packages/market-leader.html" },
    { "src": "/packages/local-dominator", "dest": "/packages/local-dominator.html" }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
    ]},
    { "source": "/images/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]},
    { "source": "/css/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]},
    { "source": "/js/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]}
  ]
}
